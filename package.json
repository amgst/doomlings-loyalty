{
  "name": "doomlings-loyalty",
  "private": true,
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "generate": "shopify app generate",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma generate && prisma migrate deploy",
    "start": "remix-serve ./build/server/index.js",
    "vercel-build": "prisma generate && prisma migrate deploy && remix vite:build"
  },
  "type": "module",
  "engines": {
    "node": ">=18.20"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@vercel/remix": "^2.13.1",
    "@remix-run/node": "^2.13.1",
    "@remix-run/react": "^2.13.1",
    "@remix-run/serve": "^2.13.1",
    "@shopify/app-bridge-react": "^4.1.4",
    "@shopify/polaris": "^13.9.2",
    "@shopify/shopify-app-remix": "^3.6.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.5",
    "isbot": "^5.1.17",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.13.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-tsconfig-paths": "^5.1.3"
  },
  "workspaces": [
    "extensions/*"
  ]
}
