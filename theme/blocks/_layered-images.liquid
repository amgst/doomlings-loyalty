{%- liquid
  assign swipe_on_mobile = block.settings.enable_swipe_on_mobile
  assign columns_mobile = block.settings.columns_mobile | plus: 0

  if block.blocks.size <= columns_mobile
    assign swipe_on_mobile = false
  endif
-%}
{%- capture inline_style -%}
  {% render 'layout-panel-style', type: 'grid', columns_mobile: columns_mobile, columns_xxl: columns_mobile %}
  {% render 'gap-style', column_gap: 8, column_gap_mobile: 8, row_gap: 8, row_gap_mobile: 8 %}
{%- endcapture -%}
<div
  class="layered-images z--1{% if swipe_on_mobile %} swipe-mobile swipe-mobile--{{ columns_mobile }}-cols{% endif %}"
  {{ block.shopify_attributes }}
>
  <div
    class="layout-panel-grid gap-style{% if swipe_on_mobile %} swipe__inner{% endif %}"
    style="{{ inline_style | strip | strip_newlines }}"
  >
    {%- for block in block.blocks -%}
      <div class="f-column">
        {% render block %}
      </div>
    {%- endfor -%}
  </div>
</div>
{% schema %}
{
  "name": "t:names.layered_images",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.mobile_layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:settings.columns",
      "default": "3",
      "options": [
        {
          "value": "1",
          "label": "t:options.grid_1_column"
        },
        {
          "value": "2",
          "label": "t:options.grid_2_column"
        },
        {
          "value": "3",
          "label": "t:options.grid_3_column"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_on_mobile",
      "label": "t:settings.enable_swipe_on_mobile",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "_layered-image"
    }
  ]
}
{% endschema %}
