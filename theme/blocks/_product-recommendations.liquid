<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  assign recommendations_type = block.settings.recommendations_type
  assign limit = block.settings.product_count
  assign heading = block.settings.heading
  assign heading_preset = block.settings.heading_preset

  assign columns_xxl = block.settings.columns_xxl
  assign columns_xl = columns_xxl | at_most: 4
  assign columns_lg = columns_xxl | at_most: 3
  assign columns_md = columns_xxl | at_most: 3
  assign columns_mobile = block.settings.columns_mobile | plus: 0
  assign enable_swipe_on_mobile = block.settings.enable_swipe_on_mobile
  assign column_gap = block.settings.column_gap

  assign swipe_mobile_classes = ''
  assign swipe_mobile_inner_classes = ''

  if enable_swipe_on_mobile
    assign swipe_mobile_classes = 'swipe-mobile swipe-mobile--[columns]-cols' | replace: '[columns]', columns_mobile
    assign swipe_mobile_inner_classes = 'swipe__inner'
  endif
%}

{%- capture container_style -%}
  {% render 'spacing-style', settings: block.settings %}
  --card-placeholder-radius: {{ settings.pcard_media_radius | divided_by: 10 }}rem;
{%- endcapture -%}

<product-recommendations
  id="product-recommendations-{{ block.id }}"
  data-url="{{ routes.product_recommendations_url }}?limit={{ limit }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-intent="{{ recommendations_type }}"
  data-recommendations-performed="{{ recommendations.performed }}"
  class="block block-product-recommendations spacing-style"
  style="{{ container_style | replace: '  ', ' ' | strip | strip_newlines }}"
  {{ block.shopify_attributes }}
>
  {% liquid
    assign products = null
    assign has_recommendations = false
    if recommendations.performed and recommendations.products_count == 0
      if recommendations_type == 'related'
        assign products = collections.all.products | reject: 'id', product.id
        assign has_recommendations = true
      elsif recommendations_type == 'complementary'
        # Do not recommend the All collection as complementary products
        assign products = null
      endif
    else
      assign products = recommendations.products
      assign has_recommendations = true
    endif
  %}
  {% if recommendations.performed %}
    {% capture list_items %}
        {% for product in products limit: limit %}
          <div class="block-product-recommendations__product swiper-slide">
            {% render 'product-card', 
              product: product, 
              show_vendor: block.settings.show_vendor, 
              show_type: block.settings.show_type, 
              show_badges: block.settings.show_badges, 
              show_swatch: block.settings.show_swatches,
              show_quick_view: block.settings.show_quick_view,
              show_quick_view_mobile: block.settings.show_quick_view,
              show_quick_add: block.settings.show_quick_add,
              show_quick_add_mobile: block.settings.show_quick_add
            %}
          </div>
        {% endfor %}
      {% endcapture %}
  {% else %}
    {% capture list_items %}
        {% for i in (1..limit) %}
          <div class="block-product-recommendations__product swiper-slide">
            <div class="block-product-recommendations__product-placeholder"></div>
          </div>
        {% endfor %}
      {% endcapture %}
  {% endif %}
  <carousel-slider
    class="carousel carousel--grid"
    data-has-recommendations="{{ has_recommendations }}"
    style="{% render 'gap-style', settings: block.settings %};--f-columns-xxl: {{ columns_xxl }};--f-columns-mobile: {{ columns_mobile }};"
  >
    <script type="application/json" ref="config">
      {
        "slidesPerView":{{ columns_md }},
        "spaceBetween": {{ column_gap }},
        "loop": false,
        "autoplay": false,
        "counter": false,
        "mousewheel": {
          "enabled": true,
          "forceToAxis": true,
          "thresholdTime": 300,
          "thresholdDelta": 10
        },
        "destroyBelow": 768,
        "breakpoints": {
          "1024": {
            "slidesPerView": {{ columns_lg }}
          },
          "1200": {
            "slidesPerView": {{ columns_xl }}
          },
          "1440": {
            "slidesPerView": {{ columns_xxl }}
          }
        }
      }
    </script>
    <div class="block-product-recommendations__heading flex items-center justify-between">
      <span class="{{ heading_preset }} rte">
        {{- heading -}}
      </span>
      {% render 'carousel-controls', ref: 'controls', type: 'group', pagination: false, counter: false %}
    </div>
    <div
      class="block-product-recommendations__products swiper {{ swipe_mobile_classes }}"
      ref="container"
    >
      <div class="swiper-wrapper layout-panel-grid-mobile gap-style {{ swipe_mobile_inner_classes }}">
        {{ list_items }}
      </div>
    </div>
  </carousel-slider>
</product-recommendations>

{% schema %}
{
  "name": "t:names.product_recommendations",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.complementary_products"
    },
    {
      "type": "select",
      "id": "recommendations_type",
      "label": "t:settings.type",
      "options": [
        { "value": "related", "label": "t:options.related" },
        { "value": "complementary", "label": "t:options.complementary" }
      ],
      "default": "related"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Complete The Look"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "t:settings.heading_preset",
      "options": [
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        }
      ],
      "default": "h5"
    },
    {
      "type": "header",
      "content": "t:settings.layout"
    },
    {
      "type": "range",
      "id": "columns_xxl",
      "label": "t:settings.desktop_columns",
      "default": 3,
      "min": 1,
      "max": 3,
      "step": 1
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "t:content.product_cards"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:settings.show_product_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_type",
      "label": "t:settings.show_product_type",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "t:settings.show_product_badges",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "t:settings.show_swatches",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "label": "t:settings.show_quick_view",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "t:settings.show_quick_add",
      "default": false
    },
    {
      "type": "header",
      "content": "t:content.mobile_layout"
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_on_mobile",
      "label": "t:settings.enable_swipe_on_mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:settings.columns",
      "options": [
        {
          "value": "1",
          "label": "t:options.grid_1_column"
        },
        {
          "value": "2",
          "label": "t:options.grid_2_column"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "row_gap_mobile",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ block.settings.enable_swipe_on_mobile == false }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile-padding-scale",
      "label": "t:settings.mobile_scale",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "t:names.product_recommendations",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
