{% comment %}
  Doomlings Loyalty — Rewards Catalog Block
  Shows available rewards. Logged-in customers can redeem directly.
{% endcomment %}

{%- liquid
  assign app_url = settings.doomlings_loyalty_app_url | default: ''
  assign color_scheme = section.settings.color_scheme | default: 'scheme-2'
  assign section_padding_top = section.settings.padding_top | default: 60
  assign section_padding_bottom = section.settings.padding_bottom | default: 60
-%}

{{ 'loyalty-widget.css' | asset_url | stylesheet_tag }}

<div
  class="loyalty-rewards-section color-{{ color_scheme }} gradient"
  style="padding-top: {{ section_padding_top }}px; padding-bottom: {{ section_padding_bottom }}px;"
>
  <div class="loyalty-container">
    <div class="section-header">
      {%- if block.settings.eyebrow != blank -%}
        <p class="loyalty-eyebrow">{{ block.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-header__title">{{ block.settings.heading | default: 'Redeem Your Points' }}</h2>
      {%- if block.settings.subheading != blank -%}
        <p class="section-header__sub">{{ block.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="loyalty-loading" id="rewards-section-loading">
      <div class="loyalty-spinner"></div>
    </div>
    <div class="loyalty-rewards-grid" id="rewards-section-grid" hidden></div>
    <div id="rewards-redeem-result" class="loyalty-alert" hidden></div>

    {%- unless customer -%}
    <div class="rewards-guest-cta">
      <p>{{ block.settings.guest_prompt | default: 'Sign in to redeem your points.' }}</p>
      <a href="{{ routes.account_login_url }}" class="btn btn--primary btn--medium">
        {{ block.settings.guest_cta | default: 'Sign In' }}
      </a>
    </div>
    {%- endunless -%}
  </div>
</div>

<style>
.section-header { text-align: center; margin-bottom: 4rem; }
.loyalty-eyebrow {
  font-family: var(--font-subheading--family, var(--font-body--family));
  font-weight: var(--font-subheading--weight, 600);
  font-size: var(--font-subheading--size, 1.3rem);
  text-transform: var(--font-subheading--transform, uppercase);
  letter-spacing: var(--font-subheading--letter-spacing, 0.08em);
  color: rgb(var(--color-foreground) / 55%);
  margin: 0 0 1rem;
}
.section-header__title {
  font-family: var(--font-heading--family);
  font-weight: var(--font-heading--weight);
  font-size: var(--font-size--h2);
  line-height: var(--font-h2--line-height, 1.3125);
  color: rgb(var(--color-foreground));
  letter-spacing: -0.03em;
  margin: 0 0 1.2rem;
}
.section-header__sub {
  font-size: var(--font-size--paragraph);
  color: rgb(var(--color-foreground) / 60%);
  max-width: 60rem;
  margin-inline: auto;
  line-height: var(--font-paragraph--line-height, 1.6);
}
.rewards-guest-cta {
  text-align: center;
  padding: 4rem 2rem;
  background: rgb(var(--color-foreground) / 4%);
  border-radius: var(--dialog-radius, 1.2rem);
  margin-top: 2.4rem;
}
.rewards-guest-cta p {
  font-size: var(--font-size--paragraph);
  color: rgb(var(--color-foreground) / 65%);
  margin-bottom: 1.6rem;
}
</style>

<script>
(function() {
  var APP_URL = {{ app_url | json }};
  var SHOP = {{ shop.permanent_domain | json }};
  {% if customer %}var EMAIL = {{ customer.email | json }};{% else %}var EMAIL = null;{% endif %}

  if (!APP_URL) {
    document.getElementById('rewards-section-loading').hidden = true;
    document.getElementById('rewards-section-grid').innerHTML = '<p class="loyalty-empty">App not configured.</p>';
    document.getElementById('rewards-section-grid').hidden = false;
    return;
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function redeemReward(id) {
    if (!EMAIL) return;
    var el = document.getElementById('rewards-redeem-result');
    el.hidden = true;
    fetch(APP_URL + '/api/loyalty?shop=' + encodeURIComponent(SHOP), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ intent: 'redeem', email: EMAIL, redemptionOptionId: id })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      el.hidden = false;
      if (data.success) {
        el.className = 'loyalty-alert loyalty-alert--success';
        el.textContent = data.code ? '✓ Reward redeemed! Code: ' + data.code : '✓ Reward redeemed!';
      } else {
        el.className = 'loyalty-alert loyalty-alert--error';
        el.textContent = '✗ ' + (data.error || 'Redemption failed.');
      }
    });
  }

  fetch(APP_URL + '/api/loyalty?shop=' + encodeURIComponent(SHOP) + '&action=rules')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var rewards = data.rewards || [];
      var grid = document.getElementById('rewards-section-grid');
      document.getElementById('rewards-section-loading').hidden = true;
      if (!rewards.length) {
        grid.innerHTML = '<p class="loyalty-empty">No rewards available yet.</p>';
      } else {
        grid.innerHTML = rewards.map(function(r) {
          var redeemBtn = EMAIL
            ? '<button class="btn btn--primary btn--medium redeem-btn" data-id="' + escHtml(r.id) + '" type="button">Redeem</button>'
            : '<a href="' + {{ routes.account_login_url | json }} + '" class="btn btn--secondary btn--medium">Sign In to Redeem</a>';
          return '<div class="loyalty-reward-card loyalty-card">' +
            '<div class="reward-card__header">' +
              '<div class="reward-card__icon">🎁</div>' +
              '<div class="reward-card__badge">' + r.pointsCost.toLocaleString() + ' pts</div>' +
            '</div>' +
            '<h3 class="reward-card__name">' + escHtml(r.name) + '</h3>' +
            '<p class="reward-card__desc">' + escHtml(r.description) + '</p>' +
            redeemBtn +
          '</div>';
        }).join('');
        grid.querySelectorAll('.redeem-btn').forEach(function(btn) {
          btn.addEventListener('click', function() { redeemReward(btn.getAttribute('data-id')); });
        });
      }
      grid.hidden = false;
    });
})();
</script>

{% schema %}
{
  "name": "Loyalty — Rewards",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ],
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Doomlings Loyalty"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Redeem Your Points"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Turn your Doomlings Points into exclusive discounts and rewards."
    },
    {
      "type": "text",
      "id": "guest_prompt",
      "label": "Guest prompt text",
      "default": "Sign in to redeem your points."
    },
    {
      "type": "text",
      "id": "guest_cta",
      "label": "Guest CTA label",
      "default": "Sign In"
    }
  ]
}
{% endschema %}
