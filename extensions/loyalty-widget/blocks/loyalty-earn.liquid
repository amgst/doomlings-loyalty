{% comment %}
  Doomlings Loyalty — Earn Points Section Block
  Shows all ways customers can earn points. Works on any page.
{% endcomment %}

{%- liquid
  assign app_url = settings.doomlings_loyalty_app_url | default: ''
  assign color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign section_padding_top = section.settings.padding_top | default: 60
  assign section_padding_bottom = section.settings.padding_bottom | default: 60
-%}

{{ 'loyalty-widget.css' | asset_url | stylesheet_tag }}

<div
  class="loyalty-earn-section color-{{ color_scheme }} gradient"
  style="padding-top: {{ section_padding_top }}px; padding-bottom: {{ section_padding_bottom }}px;"
>
  <div class="loyalty-container">
    <div class="section-header">
      {%- if block.settings.eyebrow != blank -%}
        <p class="loyalty-eyebrow">{{ block.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-header__title">{{ block.settings.heading | default: 'Ways to Earn Points' }}</h2>
      {%- if block.settings.subheading != blank -%}
        <p class="section-header__sub">{{ block.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="loyalty-loading" id="earn-section-loading">
      <div class="loyalty-spinner"></div>
    </div>
    <div class="loyalty-earn-grid" id="earn-section-grid" hidden></div>
  </div>
</div>

<style>
.section-header { text-align: center; margin-bottom: 4rem; }
.loyalty-eyebrow {
  font-family: var(--font-subheading--family, var(--font-body--family));
  font-weight: var(--font-subheading--weight, 600);
  font-size: var(--font-subheading--size, 1.3rem);
  text-transform: var(--font-subheading--transform, uppercase);
  letter-spacing: var(--font-subheading--letter-spacing, 0.08em);
  color: rgb(var(--color-foreground) / 55%);
  margin: 0 0 1rem;
}
.section-header__title {
  font-family: var(--font-heading--family);
  font-weight: var(--font-heading--weight);
  font-size: var(--font-size--h2);
  line-height: var(--font-h2--line-height, 1.3125);
  color: rgb(var(--color-foreground));
  letter-spacing: -0.03em;
  margin: 0 0 1.2rem;
}
.section-header__sub {
  font-size: var(--font-size--paragraph);
  color: rgb(var(--color-foreground) / 60%);
  max-width: 60rem;
  margin-inline: auto;
  line-height: var(--font-paragraph--line-height, 1.6);
}
</style>

<script>
(function() {
  var APP_URL = {{ app_url | json }};
  var SHOP = {{ shop.permanent_domain | json }};
  if (!APP_URL) {
    document.getElementById('earn-section-loading').hidden = true;
    document.getElementById('earn-section-grid').innerHTML = '<p class="loyalty-empty">App not configured.</p>';
    document.getElementById('earn-section-grid').hidden = false;
    return;
  }
  var ACTION_ICONS = {
    cart: '🛒', person: '👤', gift: '🎁', share: '🔗',
    star: '⭐', sparkles: '✨', heart: '❤️'
  };
  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  fetch(APP_URL + '/api/loyalty?shop=' + encodeURIComponent(SHOP) + '&action=rules')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var rules = data.earningRules || [];
      var sym = data.currencySymbol || '★';
      var grid = document.getElementById('earn-section-grid');
      document.getElementById('earn-section-loading').hidden = true;
      if (!rules.length) {
        grid.innerHTML = '<p class="loyalty-empty">No earning rules configured yet.</p>';
      } else {
        grid.innerHTML = rules.map(function(r) {
          return '<div class="loyalty-earn-card loyalty-card">' +
            '<div class="earn-card__icon">' + (ACTION_ICONS[r.icon] || '⭐') + '</div>' +
            '<div class="earn-card__info">' +
              '<h3 class="earn-card__name">' + escHtml(r.name) + '</h3>' +
              '<p class="earn-card__desc">' + escHtml(r.description) + '</p>' +
            '</div>' +
            '<div class="earn-card__points">' +
              '<span class="earn-card__pts-value">' + (r.points > 0 ? '+' : '') + r.points + '</span>' +
              '<span class="earn-card__pts-label">' + sym + ' pts</span>' +
            '</div>' +
          '</div>';
        }).join('');
      }
      grid.hidden = false;
    });
})();
</script>

{% schema %}
{
  "name": "Loyalty — Earn Points",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Doomlings Loyalty"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ways to Earn Points"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every action earns you Doomlings Points toward exclusive rewards."
    }
  ]
}
{% endschema %}
